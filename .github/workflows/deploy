name: Deploy site to GitHub Pages

on:
  push:
    branches: [main]
  workflow_dispatch:      # lets you re-run it by hand from the Actions tab

permissions:
  contents: read
  pages: write
  id-token: write

# If two pushes land close together, let the newer deploy win.
concurrency:
  group: pages
  cancel-in-progress: true

jobs:
  deploy:
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/configure-pages@v5

      # THIS is the "use /src, not the repo root" setting.
      - uses: actions/upload-pages-artifact@v3
        with:
          path: src

      - id: deployment
        uses: actions/deploy-pages@v4
